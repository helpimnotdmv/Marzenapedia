<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Marzenapedia</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Source+Sans+3:wght@300;400;600&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
<style>
:root {
  --navy: #0d1f5c;
  --gold: #b8891a;
  --offwhite: #f5f3ee;
  --text: #1a1a1a;
  --muted: #5a5a5a;
  --border: #d4cfc5;
  --link: #1a3a8f;
  --link-visited: #5b3a8f;
  --bg: #f9f7f3;
  --sidebar-bg: #f2efe9;
  --table-head: #e8e4da;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: 'Source Sans 3', sans-serif;
  font-size: 15px;
  line-height: 1.65;
  color: var(--text);
  background: var(--bg);
}

/* TOP BAR */
.topbar {
  background: var(--navy);
  color: #c8d4f0;
  font-size: 12px;
  padding: 6px 24px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  letter-spacing: 0.03em;
}
.topbar a { color: #a8bce8; text-decoration: none; }
.topbar a:hover { color: white; }
.topbar .site-name {
  font-family: 'Playfair Display', serif;
  font-size: 15px;
  color: var(--offwhite);
  letter-spacing: 0.05em;
}

/* HEADER BAND */
.site-header {
  background: var(--navy);
  border-bottom: 3px solid var(--gold);
  padding: 0 24px;
  display: flex;
  align-items: stretch;
  gap: 0;
}
.site-header .logo-area {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 12px 0;
  text-decoration: none;
  cursor: pointer;
}
.site-header .logo-area img { height: 52px; width: auto; }
.site-header .site-title {
  font-family: 'Playfair Display', serif;
  font-size: 22px;
  color: var(--offwhite);
  line-height: 1.1;
}
.site-header .site-subtitle {
  font-size: 11px;
  color: #8899cc;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-top: 2px;
}
.site-header nav {
  margin-left: auto;
  display: flex;
  align-items: center;
}
.site-header nav a {
  display: inline-flex;
  color: #b0c0e8;
  text-decoration: none;
  font-size: 13px;
  padding: 0 14px;
  height: 100%;
  align-items: center;
  border-left: 1px solid rgba(255,255,255,0.08);
  transition: background 0.15s;
  cursor: pointer;
}
.site-header nav a:hover { background: rgba(255,255,255,0.07); color: white; }
.site-header nav a.active { background: rgba(255,255,255,0.1); color: white; }

/* SEARCH BAR */
.search-bar {
  background: #e8e4da;
  border-bottom: 1px solid var(--border);
  padding: 8px 24px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.search-bar input {
  flex: 0 0 320px;
  padding: 5px 12px;
  border: 1px solid #bbb;
  border-radius: 2px;
  font-size: 13px;
  background: white;
  font-family: inherit;
}
.search-bar input:focus { outline: 2px solid var(--navy); outline-offset: 1px; }
.search-bar button {
  padding: 5px 14px;
  background: var(--navy);
  color: white;
  border: none;
  border-radius: 2px;
  font-size: 13px;
  cursor: pointer;
}
.search-bar button:hover { background: #1a3a8f; }
.search-bar .tagline {
  margin-left: 16px;
  font-size: 12px;
  color: #888;
  font-style: italic;
}

/* PAGE TABS */
.page-tabs {
  background: var(--bg);
  border-bottom: 1px solid var(--border);
  padding: 0 24px;
  display: flex;
  gap: 0;
}
.page-tabs a {
  display: inline-block;
  padding: 8px 16px;
  font-size: 13px;
  text-decoration: none;
  color: var(--muted);
  border: 1px solid transparent;
  border-bottom: none;
  margin-bottom: -1px;
  border-radius: 3px 3px 0 0;
  cursor: pointer;
}
.page-tabs a.active {
  background: var(--bg);
  border-color: var(--border);
  color: var(--text);
  font-weight: 600;
}
.page-tabs a:hover:not(.active) { color: var(--link); }

/* MAIN LAYOUT */
.layout {
  max-width: 1180px;
  margin: 0 auto;
  padding: 0 24px;
  display: flex;
  gap: 28px;
  align-items: flex-start;
}

/* LEFT TOC */
.toc-sidebar {
  flex: 0 0 210px;
  position: sticky;
  top: 16px;
  padding: 16px 0;
  font-size: 13px;
}
.toc-sidebar h3 {
  font-family: 'Crimson Pro', serif;
  font-size: 14px;
  font-weight: 600;
  color: var(--navy);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  padding-bottom: 6px;
  border-bottom: 2px solid var(--gold);
  margin-bottom: 10px;
}
.toc-sidebar ol {
  list-style: none;
  counter-reset: toc;
  padding: 0;
}
.toc-sidebar > ol > li {
  counter-increment: toc;
  margin-bottom: 3px;
}
.toc-sidebar > ol > li > a::before {
  content: counter(toc) ". ";
  color: var(--gold);
  font-weight: 600;
}
.toc-sidebar a {
  color: var(--link);
  text-decoration: none;
  display: block;
  padding: 2px 0;
}
.toc-sidebar a:hover { text-decoration: underline; }
.toc-sidebar .sub {
  padding-left: 14px;
  margin-top: 2px;
  list-style: none;
}
.toc-sidebar .sub li { margin-bottom: 2px; }
.toc-sidebar .sub a::before { content: ""; }
.toc-sidebar .sub a { color: #2a5aaa; font-size: 12px; }

/* ARTICLE */
.article { flex: 1; min-width: 0; padding: 20px 0 40px; }
.article-title {
  font-family: 'Crimson Pro', serif;
  font-size: 36px;
  font-weight: 300;
  color: var(--text);
  line-height: 1.1;
  margin-bottom: 2px;
  border-bottom: 1px solid var(--border);
  padding-bottom: 8px;
}
.article-subtitle {
  font-size: 13px;
  color: var(--muted);
  margin-bottom: 14px;
  font-style: italic;
}
.article p {
  margin-bottom: 12px;
  font-family: 'Crimson Pro', serif;
  font-size: 17px;
  line-height: 1.7;
  color: #1a1a1a;
}
.article h2 {
  font-family: 'Crimson Pro', serif;
  font-size: 24px;
  font-weight: 400;
  border-bottom: 1px solid var(--border);
  padding-bottom: 4px;
  margin: 28px 0 12px;
  color: var(--navy);
}
.article h3 {
  font-family: 'Crimson Pro', serif;
  font-size: 19px;
  font-weight: 600;
  margin: 20px 0 8px;
  color: #222;
}
.article h4 { font-size: 15px; font-weight: 700; margin: 16px 0 6px; color: #333; }
.article a { color: var(--link); text-decoration: none; cursor: pointer; }
.article a:hover { text-decoration: underline; }
.article blockquote {
  border-left: 3px solid var(--gold);
  margin: 16px 0 16px 8px;
  padding: 8px 16px;
  background: #f0ede6;
  font-style: italic;
  font-family: 'Crimson Pro', serif;
  font-size: 16px;
  color: #333;
}
.article ul, .article ol {
  margin: 0 0 12px 24px;
  font-family: 'Crimson Pro', serif;
  font-size: 17px;
  line-height: 1.7;
}
.article li { margin-bottom: 4px; }

/* TABLES */
.wiki-table { width: 100%; border-collapse: collapse; margin: 14px 0; font-size: 14px; }
.wiki-table th {
  background: var(--navy);
  color: var(--offwhite);
  padding: 7px 12px;
  text-align: left;
  font-family: 'Source Sans 3', sans-serif;
  font-weight: 600;
  font-size: 13px;
}
.wiki-table td { padding: 6px 12px; border-bottom: 1px solid var(--border); vertical-align: top; }
.wiki-table tr:nth-child(even) td { background: #f0ede6; }
.wiki-table tr:hover td { background: #e8e5dc; }

/* INFOBOX */
.infobox {
  float: right;
  clear: right;
  margin: 0 0 16px 24px;
  width: 290px;
  border: 1px solid var(--border);
  background: var(--sidebar-bg);
  font-size: 13px;
}
.infobox-title {
  background: var(--navy);
  color: var(--offwhite);
  text-align: center;
  font-family: 'Crimson Pro', serif;
  font-size: 16px;
  font-weight: 600;
  padding: 8px 12px;
  letter-spacing: 0.03em;
}
.infobox table { width: 100%; border-collapse: collapse; }
.infobox table tr td { padding: 4px 10px; border-top: 1px solid var(--border); vertical-align: top; }
.infobox table tr td:first-child {
  font-weight: 600;
  color: var(--navy);
  white-space: nowrap;
  width: 45%;
  font-size: 12px;
}

/* NOTICE / HATNOTE */
.notice-box {
  border: 1px solid #c0b898;
  background: #f8f5eb;
  padding: 10px 14px;
  margin: 0 0 16px;
  font-size: 13px;
  color: #555;
  font-style: italic;
}

/* FIGURE */
.figure-right {
  float: right;
  clear: right;
  margin: 0 0 14px 20px;
  width: 260px;
  border: 1px solid var(--border);
  background: var(--sidebar-bg);
  font-size: 12px;
}
.figure-right img { width: 100%; display: block; }
.figure-caption {
  padding: 6px 8px;
  background: #e8e4da;
  color: #555;
  font-style: italic;
  text-align: center;
  line-height: 1.4;
}

/* CLEARFIX */
.clearfix::after { content: ""; display: table; clear: both; }

/* FOOTER */
footer {
  background: var(--navy);
  color: #8899cc;
  font-size: 12px;
  padding: 20px 24px;
  margin-top: 40px;
  border-top: 3px solid var(--gold);
}
footer .footer-inner {
  max-width: 1180px;
  margin: 0 auto;
  display: flex;
  gap: 40px;
  flex-wrap: wrap;
}
footer h4 {
  color: var(--offwhite);
  font-size: 13px;
  margin-bottom: 8px;
  font-family: 'Playfair Display', serif;
}
footer a { color: #8899cc; text-decoration: none; cursor: pointer; }
footer a:hover { color: var(--offwhite); }
footer p { margin-bottom: 4px; }
.footer-note {
  max-width: 1180px;
  margin: 14px auto 0;
  border-top: 1px solid rgba(255,255,255,0.1);
  padding-top: 10px;
  font-style: italic;
  color: #667;
  font-size: 11px;
}

/* PARTY BADGES */
.party-badge { display: inline-block; padding: 1px 7px; border-radius: 2px; font-size: 11px; font-weight: 700; letter-spacing: 0.04em; }
.party-pnlr { background: #1a3a8f; color: white; }
.party-mnp { background: #8b0000; color: white; }
.party-msm { background: #c04000; color: white; }
.party-anc { background: #2d6a2d; color: white; }

/* ARTICLE LIST (homepage / all articles) */
.article-list { max-width: 1180px; margin: 0 auto; padding: 24px 24px 40px; }
.article-list h2 {
  font-family: 'Playfair Display', serif;
  font-size: 22px;
  color: var(--navy);
  border-bottom: 2px solid var(--gold);
  padding-bottom: 8px;
  margin-bottom: 20px;
}
.article-list .article-card {
  border: 1px solid var(--border);
  background: white;
  padding: 16px 20px;
  margin-bottom: 12px;
  border-radius: 2px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  cursor: pointer;
  transition: border-color 0.15s, background 0.15s;
}
.article-card:hover { border-color: var(--navy); background: #f5f3fa; }
.article-card h3 {
  font-family: 'Crimson Pro', serif;
  font-size: 20px;
  color: var(--link);
  font-weight: 400;
  margin-bottom: 4px;
}
.article-card p { font-size: 13px; color: var(--muted); }
.article-card .meta { font-size: 12px; color: #999; text-align: right; white-space: nowrap; margin-left: 16px; }

/* LOADING STATE */
.loading {
  text-align: center;
  padding: 60px 24px;
  color: var(--muted);
  font-style: italic;
  font-family: 'Crimson Pro', serif;
  font-size: 18px;
}

/* ERROR STATE */
.error-msg {
  max-width: 600px;
  margin: 40px auto;
  padding: 24px;
  background: #fff8f8;
  border: 1px solid #e0a0a0;
  border-radius: 2px;
  text-align: center;
}
.error-msg h2 { font-family: 'Crimson Pro', serif; color: #8b0000; margin-bottom: 8px; }
.error-msg p { color: var(--muted); font-size: 14px; }

/* SEARCH RESULTS */
.search-results { max-width: 1180px; margin: 0 auto; padding: 24px 24px 40px; }
.search-results h2 { font-family: 'Playfair Display', serif; font-size: 20px; color: var(--navy); margin-bottom: 16px; }
.search-result-item { border-bottom: 1px solid var(--border); padding: 14px 0; cursor: pointer; }
.search-result-item:hover h3 { text-decoration: underline; }
.search-result-item h3 { font-family: 'Crimson Pro', serif; font-size: 18px; color: var(--link); font-weight: 400; margin-bottom: 4px; }
.search-result-item p { font-size: 13px; color: var(--muted); }
.search-result-item mark { background: #fffacc; }

@media (max-width: 900px) {
  .toc-sidebar { display: none; }
  .infobox { width: 240px; }
}
@media (max-width: 640px) {
  .infobox { float: none; width: 100%; margin: 0 0 16px; }
  .layout { flex-direction: column; }
  .site-header nav { display: none; }
}
</style>
</head>
<body>

<div class="topbar">
  <span class="site-name">Marzenapedia</span>
  <span>
    The Free Encyclopaedia of the Republic &nbsp;·&nbsp;
    <a href="#" onclick="navigate('home')">Main Page</a> &nbsp;·&nbsp;
    <a href="#" onclick="navigate('all')">All Articles</a> &nbsp;·&nbsp;
    <a href="#" onclick="showHelp()">Help</a>
  </span>
</div>

<header class="site-header">
  <div class="logo-area" onclick="navigate('home')">
    <div>
      <div class="site-title">Marzenapedia</div>
      <div class="site-subtitle">The Free Encyclopaedia of the Republic</div>
    </div>
  </div>
  <nav id="main-nav">
    <!-- populated by JS -->
  </nav>
</header>

<div class="search-bar">
  <input type="text" id="search-input" placeholder="Search Marzenapedia…" onkeydown="if(event.key==='Enter') doSearch()">
  <button onclick="doSearch()">Search</button>
  <span class="tagline" id="search-tagline">Fictional nation · Worldbuilding reference</span>
</div>

<div class="page-tabs" id="page-tabs">
  <a class="active" id="tab-article" onclick="switchTab('article')">Article</a>
  <a id="tab-edit" onclick="openEditor()">Edit</a>
</div>

<div id="main-content">
  <div class="loading">Loading Marzenapedia…</div>
</div>

<footer>
  <div class="footer-inner">
    <div>
      <h4>Marzenapedia</h4>
      <p>The Free Encyclopaedia of the Republic</p>
      <p>Fictional nation · Worldbuilding reference</p>
    </div>
    <div>
      <h4>Navigation</h4>
      <p><a onclick="navigate('home')">Main Page</a></p>
      <p><a onclick="navigate('all')">All Articles</a></p>
      <p><a onclick="doSearch()">Search</a></p>
    </div>
    <div>
      <h4>About</h4>
      <p><a onclick="showHelp()">How to edit articles</a></p>
      <p>Powered by GitHub Pages</p>
    </div>
  </div>
  <div class="footer-note">All content on Marzenapedia is fictional and created for worldbuilding and narrative purposes. No real nation, person, or event is represented.</div>
</footer>

<!-- EDITOR MODAL -->
<div id="editor-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:1000;overflow-y:auto;">
  <div style="background:white;max-width:800px;margin:40px auto;border-radius:2px;overflow:hidden;box-shadow:0 8px 32px rgba(0,0,0,0.3);">
    <div style="background:var(--navy);color:white;padding:14px 20px;display:flex;justify-content:space-between;align-items:center;">
      <span style="font-family:'Playfair Display',serif;font-size:18px;" id="editor-title">Edit Article</span>
      <button onclick="closeEditor()" style="background:none;border:none;color:white;font-size:20px;cursor:pointer;line-height:1;">×</button>
    </div>
    <div style="padding:20px;">
      <div style="margin-bottom:12px;">
        <label style="display:block;font-size:13px;font-weight:600;margin-bottom:4px;color:var(--navy);">Article Title (filename, e.g. republic-of-marzena)</label>
        <input id="editor-filename" type="text" style="width:100%;padding:6px 10px;border:1px solid var(--border);font-size:14px;font-family:monospace;" placeholder="article-slug">
      </div>
      <div style="margin-bottom:12px;">
        <label style="display:block;font-size:13px;font-weight:600;margin-bottom:4px;color:var(--navy);">
          Content (Markdown)
          <span style="font-weight:400;color:var(--muted);margin-left:8px;">· Use # for h1, ## for h2, **bold**, [[Article Name]] for wiki links</span>
        </label>
        <textarea id="editor-content" style="width:100%;height:420px;padding:10px;border:1px solid var(--border);font-size:13px;font-family:monospace;line-height:1.6;resize:vertical;" placeholder="Write your article in Markdown…"></textarea>
      </div>
      <div style="display:flex;gap:10px;justify-content:flex-end;border-top:1px solid var(--border);padding-top:14px;">
        <button onclick="previewArticle()" style="padding:8px 18px;background:#f0ede6;border:1px solid var(--border);cursor:pointer;font-family:inherit;font-size:13px;">Preview</button>
        <button onclick="closeEditor()" style="padding:8px 18px;background:#f0ede6;border:1px solid var(--border);cursor:pointer;font-family:inherit;font-size:13px;">Cancel</button>
        <button onclick="saveArticle()" style="padding:8px 18px;background:var(--navy);color:white;border:none;cursor:pointer;font-family:inherit;font-size:13px;">Save to GitHub</button>
      </div>
    </div>
  </div>
</div>

<!-- HELP MODAL -->
<div id="help-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:1000;overflow-y:auto;">
  <div style="background:white;max-width:660px;margin:40px auto;border-radius:2px;overflow:hidden;box-shadow:0 8px 32px rgba(0,0,0,0.3);">
    <div style="background:var(--navy);color:white;padding:14px 20px;display:flex;justify-content:space-between;align-items:center;">
      <span style="font-family:'Playfair Display',serif;font-size:18px;">How to Edit Marzenapedia</span>
      <button onclick="document.getElementById('help-overlay').style.display='none'" style="background:none;border:none;color:white;font-size:20px;cursor:pointer;line-height:1;">×</button>
    </div>
    <div style="padding:24px;font-size:14px;line-height:1.7;">
      <h3 style="font-family:'Crimson Pro',serif;font-size:20px;color:var(--navy);margin-bottom:12px;">Writing Articles</h3>
      <p style="margin-bottom:12px;">Articles are written in <strong>Markdown</strong> and stored as <code>.md</code> files in the <code>articles/</code> folder of the GitHub repository.</p>
      <p style="margin-bottom:16px;">Click the <strong>Edit</strong> tab on any article, write your content, and click <strong>Save to GitHub</strong>. The page will give you a direct link to commit the file on GitHub.com.</p>

      <h3 style="font-family:'Crimson Pro',serif;font-size:18px;color:var(--navy);margin:16px 0 8px;">Markdown Cheat Sheet</h3>
      <table style="width:100%;font-size:13px;border-collapse:collapse;margin-bottom:16px;">
        <tr style="background:#f0ede6;"><td style="padding:5px 10px;font-family:monospace;"># Title</td><td style="padding:5px 10px;">Article h1 title</td></tr>
        <tr><td style="padding:5px 10px;font-family:monospace;">## Section</td><td style="padding:5px 10px;">Section heading (h2)</td></tr>
        <tr style="background:#f0ede6;"><td style="padding:5px 10px;font-family:monospace;">### Subsection</td><td style="padding:5px 10px;">Subsection (h3)</td></tr>
        <tr><td style="padding:5px 10px;font-family:monospace;">**bold**</td><td style="padding:5px 10px;"><strong>bold text</strong></td></tr>
        <tr style="background:#f0ede6;"><td style="padding:5px 10px;font-family:monospace;">*italic*</td><td style="padding:5px 10px;"><em>italic text</em></td></tr>
        <tr><td style="padding:5px 10px;font-family:monospace;">[[Article Name]]</td><td style="padding:5px 10px;">Link to another wiki article</td></tr>
        <tr style="background:#f0ede6;"><td style="padding:5px 10px;font-family:monospace;">&gt; Quote text</td><td style="padding:5px 10px;">Blockquote</td></tr>
        <tr><td style="padding:5px 10px;font-family:monospace;">- item</td><td style="padding:5px 10px;">Bullet list</td></tr>
      </table>

      <h3 style="font-family:'Crimson Pro',serif;font-size:18px;color:var(--navy);margin:16px 0 8px;">Infobox Syntax</h3>
      <pre style="background:#f0ede6;padding:10px;font-size:12px;overflow-x:auto;">:::infobox
title: Republic of Marzena
Capital: Solane
Population: 41.2 million
:::</pre>

      <h3 style="font-family:'Crimson Pro',serif;font-size:18px;color:var(--navy);margin:16px 0 8px;">Saving via GitHub</h3>
      <p>When you click "Save to GitHub", the editor will generate a pre-filled GitHub commit URL. You'll be taken to GitHub.com to confirm. The article will be live within seconds.</p>
    </div>
  </div>
</div>

<script>
// ═══════════════════════════════════════════════
// CONFIGURATION
// ═══════════════════════════════════════════════
const REPO_OWNER = 'helpimnotdmv';
const REPO_NAME = 'Marzenapedia';
const BRANCH = 'main';
const ARTICLES_PATH = 'articles';

// GitHub API base (no token needed for public repos, just rate-limited)
const API_BASE = `https://api.github.com/repos/${REPO_OWNER}/${REPO_NAME}`;
const RAW_BASE = `https://raw.githubusercontent.com/${REPO_OWNER}/${REPO_NAME}/${BRANCH}`;

// ═══════════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════════
let currentView = 'home';   // 'home' | 'article' | 'all' | 'search'
let currentSlug = null;
let articleCache = {};
let articleIndex = null;   // list of {slug, title, summary}

// ═══════════════════════════════════════════════
// ROUTING
// ═══════════════════════════════════════════════
function navigate(target, slug) {
  if (target === 'article' && slug) {
    currentView = 'article';
    currentSlug = slug;
    loadArticle(slug);
  } else if (target === 'all') {
    currentView = 'all';
    currentSlug = null;
    showAllArticles();
  } else if (target === 'search') {
    currentView = 'search';
  } else {
    currentView = 'home';
    currentSlug = null;
    showHome();
  }
  updateNav();
  window.scrollTo(0, 0);
}

function updateNav() {
  document.getElementById('page-tabs').style.display = currentView === 'article' ? 'flex' : 'none';
}

// ═══════════════════════════════════════════════
// FETCH ARTICLE LIST
// ═══════════════════════════════════════════════
async function fetchArticleIndex() {
  if (articleIndex) return articleIndex;
  try {
    const res = await fetch(`${API_BASE}/git/trees/${BRANCH}?recursive=1`);
    if (!res.ok) throw new Error('GitHub API error');
    const data = await res.json();
    const mdFiles = (data.tree || []).filter(f => f.path.startsWith(ARTICLES_PATH + '/') && f.path.endsWith('.md'));
    // Build index: slug from filename
    const index = mdFiles.map(f => {
      const slug = f.path.replace(ARTICLES_PATH + '/', '').replace('.md', '');
      return { slug, path: f.path, sha: f.sha };
    });
    articleIndex = index;
    return index;
  } catch (e) {
    console.error('Failed to fetch article index:', e);
    return [];
  }
}

// ═══════════════════════════════════════════════
// FETCH ARTICLE CONTENT
// ═══════════════════════════════════════════════
async function fetchArticleContent(slug) {
  if (articleCache[slug]) return articleCache[slug];
  const url = `${RAW_BASE}/${ARTICLES_PATH}/${slug}.md?t=${Date.now()}`;
  const res = await fetch(url);
  if (!res.ok) throw new Error(`Article not found: ${slug}`);
  const text = await res.text();
  articleCache[slug] = text;
  return text;
}

// ═══════════════════════════════════════════════
// MARKDOWN PARSER (lightweight)
// ═══════════════════════════════════════════════
function parseMarkdown(md) {
  let html = md;

  // Infobox: :::infobox ... :::
  html = html.replace(/:::infobox\n([\s\S]*?):::/g, (_, inner) => {
    const lines = inner.trim().split('\n');
    let title = '';
    const rows = [];
    lines.forEach(line => {
      const m = line.match(/^([^:]+):\s*(.+)$/);
      if (m) {
        if (m[1].trim().toLowerCase() === 'title') title = m[2].trim();
        else rows.push(`<tr><td>${m[1].trim()}</td><td>${m[2].trim()}</td></tr>`);
      }
    });
    return `<div class="infobox"><div class="infobox-title">${title || 'Infobox'}</div><table>${rows.join('')}</table></div>`;
  });

  // Tables
  html = html.replace(/(\|.+\|\n)+/g, tableBlock => {
    const rows = tableBlock.trim().split('\n').filter(r => !r.match(/^\|[-| ]+\|$/));
    return '<table class="wiki-table">' + rows.map((r, i) => {
      const cells = r.split('|').slice(1, -1).map(c => c.trim());
      const tag = i === 0 ? 'th' : 'td';
      return `<tr>${cells.map(c => `<${tag}>${c}</${tag}>`).join('')}</tr>`;
    }).join('') + '</table>';
  });

  // Headings
  html = html.replace(/^#### (.+)$/gm, '<h4>$1</h4>');
  html = html.replace(/^### (.+)$/gm, '<h3 id="$1">$1</h3>');
  html = html.replace(/^## (.+)$/gm, (_, t) => `<h2 id="${t.replace(/\s+/g, '-').toLowerCase()}">${t}</h2>`);
  html = html.replace(/^# (.+)$/gm, '<!-- title:$1 -->');

  // Blockquotes
  html = html.replace(/^> (.+)$/gm, '<blockquote>$1</blockquote>');

  // Bold / italic
  html = html.replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>');
  html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
  html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');

  // Wiki links [[Article Name]]
  html = html.replace(/\[\[([^\]]+)\]\]/g, (_, name) => {
    const slug = name.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
    return `<a onclick="navigate('article','${slug}')">${name}</a>`;
  });

  // Regular links [text](url)
  html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>');

  // Unordered lists
  html = html.replace(/(^- .+\n?)+/gm, block => {
    const items = block.trim().split('\n').map(l => `<li>${l.replace(/^- /, '')}</li>`).join('');
    return `<ul>${items}</ul>`;
  });

  // Ordered lists
  html = html.replace(/(^\d+\. .+\n?)+/gm, block => {
    const items = block.trim().split('\n').map(l => `<li>${l.replace(/^\d+\. /, '')}</li>`).join('');
    return `<ol>${items}</ol>`;
  });

  // Horizontal rule
  html = html.replace(/^---$/gm, '<hr style="border:none;border-top:1px solid var(--border);margin:20px 0;">');

  // Paragraphs: wrap lines that are not already HTML
  const lines = html.split('\n');
  const out = [];
  let inPara = false;
  for (const line of lines) {
    const trimmed = line.trim();
    if (!trimmed) {
      if (inPara) { out.push('</p>'); inPara = false; }
      continue;
    }
    if (trimmed.match(/^<(h[1-6]|ul|ol|table|blockquote|div|hr|<!--|p>)/)) {
      if (inPara) { out.push('</p>'); inPara = false; }
      out.push(trimmed);
    } else {
      if (!inPara) { out.push('<p>'); inPara = true; }
      out.push(trimmed + ' ');
    }
  }
  if (inPara) out.push('</p>');
  html = out.join('\n');

  return html;
}

function extractTitle(md) {
  const m = md.match(/^# (.+)$/m);
  return m ? m[1].trim() : null;
}

function extractSummary(md) {
  // First paragraph after title
  const lines = md.split('\n');
  let pastTitle = false;
  for (const l of lines) {
    if (!pastTitle && l.startsWith('# ')) { pastTitle = true; continue; }
    if (pastTitle && l.trim() && !l.startsWith('#')) return l.trim().slice(0, 120) + '…';
  }
  return '';
}

// ═══════════════════════════════════════════════
// BUILD TOC
// ═══════════════════════════════════════════════
function buildToc(html) {
  const matches = [...html.matchAll(/<h2 id="([^"]+)">([^<]+)<\/h2>/g)];
  if (matches.length < 2) return '';
  const items = matches.map((m, i) =>
    `<li><a href="#${m[1]}">${m[2]}</a></li>`
  ).join('');
  return `<div class="toc-sidebar"><h3>Contents</h3><ol>${items}</ol></div>`;
}

// ═══════════════════════════════════════════════
// VIEWS
// ═══════════════════════════════════════════════
async function showHome() {
  document.getElementById('main-content').innerHTML = '<div class="loading">Loading articles…</div>';
  document.title = 'Marzenapedia — Main Page';
  const index = await fetchArticleIndex();

  if (index.length === 0) {
    document.getElementById('main-content').innerHTML = `
      <div class="article-list">
        <h2>Welcome to Marzenapedia</h2>
        <div class="notice-box">No articles found yet. Click <strong>Edit</strong> on any article to start writing, or use the navigation to create the first article.</div>
        <div class="article-card" onclick="openNewArticle()">
          <div>
            <h3>+ Create the first article</h3>
            <p>Click to open the editor and write your first wiki article.</p>
          </div>
        </div>
      </div>`;
    return;
  }

  // Fetch titles for display
  const cards = await Promise.all(index.map(async item => {
    try {
      const content = await fetchArticleContent(item.slug);
      const title = extractTitle(content) || slugToTitle(item.slug);
      const summary = extractSummary(content);
      return { slug: item.slug, title, summary };
    } catch {
      return { slug: item.slug, title: slugToTitle(item.slug), summary: '' };
    }
  }));

  const cardsHtml = cards.map(c => `
    <div class="article-card" onclick="navigate('article','${c.slug}')">
      <div>
        <h3>${c.title}</h3>
        <p>${c.summary}</p>
      </div>
      <div class="meta">${c.slug}</div>
    </div>`).join('');

  document.getElementById('main-content').innerHTML = `
    <div class="article-list">
      <h2>Marzenapedia — Main Page</h2>
      <p style="font-family:'Crimson Pro',serif;font-size:16px;color:var(--muted);margin-bottom:20px;">
        The free encyclopaedia of the fictional Republic of Marzena. ${cards.length} article${cards.length !== 1 ? 's' : ''} and counting.
      </p>
      ${cardsHtml}
      <div class="article-card" onclick="openNewArticle()" style="border-style:dashed;margin-top:20px;">
        <div><h3 style="color:var(--muted);">+ New Article</h3><p>Open the editor to write a new article.</p></div>
      </div>
    </div>`;
}

async function showAllArticles() {
  document.getElementById('main-content').innerHTML = '<div class="loading">Loading article index…</div>';
  document.title = 'All Articles — Marzenapedia';
  const index = await fetchArticleIndex();

  const cards = await Promise.all(index.map(async item => {
    try {
      const content = await fetchArticleContent(item.slug);
      const title = extractTitle(content) || slugToTitle(item.slug);
      return { slug: item.slug, title };
    } catch {
      return { slug: item.slug, title: slugToTitle(item.slug) };
    }
  }));

  const rows = cards.sort((a,b) => a.title.localeCompare(b.title))
    .map(c => `<div class="search-result-item" onclick="navigate('article','${c.slug}')">
      <h3>${c.title}</h3><p>${c.slug}.md</p></div>`).join('');

  document.getElementById('main-content').innerHTML = `
    <div class="search-results">
      <h2>All Articles (${cards.length})</h2>
      ${rows}
      <div class="article-card" onclick="openNewArticle()" style="border-style:dashed;margin-top:20px;border:1px dashed var(--border);background:white;padding:16px 20px;cursor:pointer;">
        <div><h3 style="color:var(--muted);font-family:'Crimson Pro',serif;font-weight:400;">+ New Article</h3></div>
      </div>
    </div>`;
}

async function loadArticle(slug) {
  document.getElementById('main-content').innerHTML = '<div class="loading">Loading article…</div>';
  document.title = `${slugToTitle(slug)} — Marzenapedia`;

  try {
    const md = await fetchArticleContent(slug);
    const title = extractTitle(md) || slugToTitle(slug);
    const bodyMd = md.replace(/^# .+\n/, ''); // strip h1
    const bodyHtml = parseMarkdown(bodyMd);
    const toc = buildToc(bodyHtml);
    document.title = `${title} — Marzenapedia`;

    document.getElementById('main-content').innerHTML = `
      <div class="layout">
        ${toc}
        <article class="article clearfix">
          <div class="article-title">${title}</div>
          ${bodyHtml}
          <div style="clear:both;border-top:1px solid var(--border);margin-top:30px;padding-top:10px;font-size:12px;color:#888;font-style:italic;">
            Marzenapedia &nbsp;·&nbsp; Fictional sovereign state &nbsp;·&nbsp; Worldbuilding reference
          </div>
        </article>
      </div>`;

    // Scroll to hash
    if (location.hash) {
      const el = document.querySelector(location.hash);
      if (el) el.scrollIntoView();
    }
  } catch (e) {
    document.getElementById('main-content').innerHTML = `
      <div class="error-msg">
        <h2>Article Not Found</h2>
        <p>The article "<strong>${slug}</strong>" does not exist yet.</p>
        <p style="margin-top:12px;"><a onclick="openNewArticle('${slug}')" style="color:var(--link);cursor:pointer;">Create this article →</a></p>
      </div>`;
  }
}

// ═══════════════════════════════════════════════
// SEARCH
// ═══════════════════════════════════════════════
async function doSearch() {
  const q = document.getElementById('search-input').value.trim();
  if (!q) return;
  document.getElementById('main-content').innerHTML = '<div class="loading">Searching…</div>';
  document.getElementById('page-tabs').style.display = 'none';
  document.title = `Search: ${q} — Marzenapedia`;

  const index = await fetchArticleIndex();
  const results = [];

  await Promise.all(index.map(async item => {
    try {
      const content = await fetchArticleContent(item.slug);
      const title = extractTitle(content) || slugToTitle(item.slug);
      const lower = content.toLowerCase();
      const ql = q.toLowerCase();
      if (lower.includes(ql) || title.toLowerCase().includes(ql)) {
        const idx = lower.indexOf(ql);
        const snippet = content.slice(Math.max(0, idx - 60), idx + 120)
          .replace(/\n/g, ' ')
          .replace(new RegExp(q, 'gi'), m => `<mark>${m}</mark>`);
        results.push({ slug: item.slug, title, snippet });
      }
    } catch {}
  }));

  if (results.length === 0) {
    document.getElementById('main-content').innerHTML = `
      <div class="search-results">
        <h2>No results for "${q}"</h2>
        <p style="color:var(--muted);">No articles matched your search. <a onclick="openNewArticle()" style="color:var(--link);cursor:pointer;">Create a new article →</a></p>
      </div>`;
    return;
  }

  const rows = results.map(r => `
    <div class="search-result-item" onclick="navigate('article','${r.slug}')">
      <h3>${r.title}</h3>
      <p>…${r.snippet}…</p>
    </div>`).join('');

  document.getElementById('main-content').innerHTML = `
    <div class="search-results">
      <h2>Search results for "${q}" (${results.length})</h2>
      ${rows}
    </div>`;
}

// ═══════════════════════════════════════════════
// EDITOR
// ═══════════════════════════════════════════════
function openEditor() {
  if (!currentSlug) { openNewArticle(); return; }
  // Pre-fill with current article content
  fetchArticleContent(currentSlug).then(md => {
    document.getElementById('editor-filename').value = currentSlug;
    document.getElementById('editor-content').value = md;
    document.getElementById('editor-title').textContent = `Edit: ${slugToTitle(currentSlug)}`;
    document.getElementById('editor-overlay').style.display = 'block';
  }).catch(() => {
    document.getElementById('editor-filename').value = currentSlug;
    document.getElementById('editor-content').value = `# ${slugToTitle(currentSlug)}\n\nWrite your article here.\n`;
    document.getElementById('editor-title').textContent = `Edit: ${slugToTitle(currentSlug)}`;
    document.getElementById('editor-overlay').style.display = 'block';
  });
}

function openNewArticle(slug) {
  const s = slug || '';
  document.getElementById('editor-filename').value = s;
  document.getElementById('editor-content').value = s ? `# ${slugToTitle(s)}\n\nWrite your article here.\n` : '';
  document.getElementById('editor-title').textContent = 'New Article';
  document.getElementById('editor-overlay').style.display = 'block';
}

function closeEditor() {
  document.getElementById('editor-overlay').style.display = 'none';
}

function previewArticle() {
  const md = document.getElementById('editor-content').value;
  const slug = document.getElementById('editor-filename').value || 'preview';
  articleCache[slug] = md;
  closeEditor();
  navigate('article', slug);
}

function saveArticle() {
  const slug = document.getElementById('editor-filename').value.trim().toLowerCase().replace(/\s+/g, '-');
  const content = document.getElementById('editor-content').value;

  if (!slug) { alert('Please enter a filename (slug) for the article.'); return; }
  if (!content.trim()) { alert('Article content is empty.'); return; }

  // Encode content for GitHub URL
  const encoded = encodeURIComponent(content);
  const filename = `${ARTICLES_PATH}/${slug}.md`;

  // Build GitHub new/edit file URL
  // The "new file" flow requires the user to log in and commit
  const githubUrl = `https://github.com/${REPO_OWNER}/${REPO_NAME}/new/${BRANCH}?filename=${encodeURIComponent(filename)}&value=${encoded}`;

  // For existing files, we'd need the SHA — simpler to always use "new" flow (GitHub handles both)
  alert(`You'll be taken to GitHub to save this article.\n\nFile: ${filename}\n\nIf the file already exists, GitHub will ask you to choose a branch or will update it.`);
  window.open(githubUrl, '_blank');

  // Optimistically cache and update
  articleCache[slug] = content;
  articleIndex = null; // invalidate index
  closeEditor();
}

// ═══════════════════════════════════════════════
// HELP MODAL
// ═══════════════════════════════════════════════
function showHelp() {
  document.getElementById('help-overlay').style.display = 'block';
}

function switchTab(tab) {
  if (tab === 'article') {
    document.getElementById('tab-article').classList.add('active');
    document.getElementById('tab-edit').classList.remove('active');
  }
}

// ═══════════════════════════════════════════════
// UTILITIES
// ═══════════════════════════════════════════════
function slugToTitle(slug) {
  return slug.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
}

// Build nav from article index
async function buildNav() {
  const index = await fetchArticleIndex();
  const nav = document.getElementById('main-nav');
  const shown = index.slice(0, 5);
  nav.innerHTML = shown.map(item =>
    `<a onclick="navigate('article','${item.slug}')">${slugToTitle(item.slug).split(' ')[0]}</a>`
  ).join('') + `<a onclick="navigate('all')">All Articles</a>`;
}

// Close modals on overlay click
document.getElementById('editor-overlay').addEventListener('click', e => {
  if (e.target === document.getElementById('editor-overlay')) closeEditor();
});
document.getElementById('help-overlay').addEventListener('click', e => {
  if (e.target === document.getElementById('help-overlay')) document.getElementById('help-overlay').style.display = 'none';
});

// ═══════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════
(async function init() {
  updateNav();
  await buildNav();

  // Hash-based routing
  const hash = location.hash.replace('#', '');
  if (hash && hash !== 'home') {
    navigate('article', hash);
  } else {
    navigate('home');
  }
})();
</script>
</body>
</html>
